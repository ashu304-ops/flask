pipeline {
    agent any

    environment {
        IMAGE_NAME = 'flask-jenkins-app'
    }
    triggers {
        pollSCM('H/5 * * * *') // Poll SCM every 5 minutes
    }

    stages {
        stage('Clone') {
            steps {
                git branch: 'main', url: 'https://github.com/ashu304-ops/flask.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t ${IMAGE_NAME} .'
            }
        }

        stage('Test Container') {
            steps {
                sh '''
                    docker run -d --name test-container -p 5000:5000 ${IMAGE_NAME}
                    sleep 5
                    curl -f http://localhost:5000
                    curl -f http://localhost:5000/about
                    curl -f http://localhost:5000/hello/ashu
                    docker stop test-container
                    docker rm test-container
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    docker stop flask-app || true
                    docker rm flask-app || true
                    docker run -d --name flask-app -p 5000:5000 ${IMAGE_NAME}
                '''
            }
        }
    }

    post {
        always {
            echo 'Pipeline finished and succes  it .'
        }
    }
}
